# HomePlus Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OPENCLAW GATEWAY (REQUIRED)
# =============================================================================

# WebSocket URL of your OpenClaw Gateway
# For local gateway: ws://127.0.0.1:18789
# For remote gateway: ws://<gateway-ip>:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (REQUIRED)
# Find this in your OpenClaw configuration:
# - Local: cat ~/.openclaw/openclaw.json | grep token
# Or in OpenClaw Control UI > Settings > Gateway
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# =============================================================================
# HOMEPLUS SERVER PORTS
# =============================================================================

# HTTP port for the web UI
HOMEPLUS_HTTP_PORT=18790

# WebSocket port for real-time messaging
HOMEPLUS_WS_PORT=18791

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info
