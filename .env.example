# HomePlus Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OPENCLAW GATEWAY (REQUIRED)
# =============================================================================

# WebSocket URL of your OpenClaw Gateway
# For local gateway: ws://127.0.0.1:18789
# For remote gateway: ws://<gateway-ip>:18789
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (REQUIRED)
# Find this in your OpenClaw configuration:
# - Local: cat ~/.openclaw/openclaw.json | grep token
# Or in OpenClaw Control UI > Settings > Gateway
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# =============================================================================
# MINIMAX API (REQUIRED)
# =============================================================================

# MiniMax API Key (required for AI chat)
# Get your API key from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax API base URL (usually don't need to change)
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1

# Model to use (default: MiniMax-M2.7-highspeed)
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# =============================================================================
# HOMEPLUS SERVER PORTS
# =============================================================================

# HTTP port for the web UI
HOMEPLUS_HTTP_PORT=18790

# WebSocket port for real-time messaging
HOMEPLUS_WS_PORT=18791

# =============================================================================
# SECURITY
# =============================================================================

# Secret for /ai-response endpoint HMAC verification
# Generate a random secret: openssl rand -hex 32
# Leave empty to disable authentication (NOT recommended for production)
AI_RESPONSE_SECRET=

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info
